DB_DATA_LOCATION=./postgres
UPLOAD_LOCATION=/data

TZ=Europe/Saratov

IMMICH_VERSION=release

# Machine learning backend: cpu, cuda, rocm, openvino, openvino-wsl, armnn, rknn
IMMICH_ML_ACCEL=cpu
# Leave empty for CPU. Set to -cuda, -rocm, -openvino, -openvino-wsl, -armnn, or -rknn when matching the backend above.
IMMICH_ML_IMAGE_SUFFIX=

DB_DATABASE_NAME=immich
DB_PASSWORD=immich
DB_USERNAME=postgres
